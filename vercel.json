{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/projets", "destination": "/pages/realisations.html" },
    { "source": "/projet", "destination": "/pages/realisation.html" },
    { "source": "/realisations", "destination": "/pages/realisations.html" },
    { "source": "/realisation", "destination": "/pages/realisation.html" },
    { "source": "/a-propos", "destination": "/pages/a-propos.html" },
    { "source": "/contact", "destination": "/pages/contact.html" }
  ],
  "headers": [
    {
      "source": "/styles/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0, s-maxage=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "X-Content-Version",
          "value": "8"
        }
      ]
    },
    {
      "source": "/scripts/(.*)",
